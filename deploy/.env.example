# Production env file — copy to /opt/shortly/.env on the EC2 server.
# Never commit the real values. .env is already in the project's .gitignore.

# ── GHCR image owner (your GitHub username, lowercase) ──────────────
GITHUB_OWNER=baljeetx

# ── Domains ──────────────────────────────────────────────────────────
FRONTEND_DOMAIN=shortly.example.com         # Vercel-served SPA
API_DOMAIN=api.shortly.example.com          # this EC2 box
ACME_EMAIL=you@example.com                  # Let's Encrypt notifications

# ── Supabase (Postgres) ──────────────────────────────────────────────
# Get these from Supabase dashboard → Project Settings → Database →
# Connection string (use the "Transaction pooler" or "Session pooler" host;
# port 5432 for direct, 6543 for pooler).
#
# Important: in JDBC the user/password come out of the URL as separate fields.
# Strip them when copying.
SUPABASE_DB_URL=jdbc:postgresql://aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=replace-me

# ── JWT signing key (generate fresh: openssl rand -base64 64) ────────
JWT_SECRET=replace-with-a-long-random-base64-string-at-least-32-bytes

# ── Google OAuth (from Google Cloud Console → Auth → Clients) ────────
# IMPORTANT: in the Google client, add the prod redirect URI:
#   https://api.shortly.example.com/login/oauth2/code/google
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-replace-me

# ── Grafana Cloud Loki (only needed if promtail service is enabled) ──
# Get these from Grafana Cloud → My Account → Stack → Loki → Details
GRAFANA_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=123456
GRAFANA_LOKI_TOKEN=glc_replace-me
